<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script>
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "background": "#09090b",
            "on-background": "#fafafa",
            "surface": "#0c0c0f",
            "surface-container": "#121215",
            "surface-container-lowest": "#09090b",
            "surface-container-high": "#18181b",
            "on-surface": "#fafafa",
            "on-surface-variant": "#a1a1aa",
            "primary": "#a78bfa",
            "on-primary": "#0a0012",
            "primary-container": "#7c3aed",
            "outline-variant": "#27272a",
            "outline": "#52525b",
            "error": "#ef4444",
            "error-container": "#3b1111",
            "on-error-container": "#fca5a5",
          },
          fontFamily: {
            "body": ["Geist", "sans-serif"],
          }
        }
      }
    }
  </script>
  <style>
    body { font-family: 'Geist', sans-serif; }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-background min-h-screen w-full flex items-center justify-center font-body antialiased";
    });
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-background min-h-screen w-full flex items-center justify-center font-body antialiased";
    });
  </script>
<% end %>

<div class="w-full max-w-md px-6">
  <!-- Logo & Title -->
  <div class="flex flex-col items-center mb-10">
    <%= image_tag "logo-big.png", class: "w-32 h-32 object-contain" %>
    <h1 class="text-3xl font-black tracking-tighter text-on-surface">Azaleia</h1>
    <p class="text-sm text-on-surface-variant mt-1"><%= t('auth.sessions.new.title') %></p>
  </div>

  <!-- Flash Messages -->
  <% if flash[:alert] %>
    <div class="mb-6 p-4 bg-error-container text-on-error-container rounded-lg border border-error/50 text-sm font-medium">
      <%= flash[:alert] %>
    </div>
  <% end %>
  <% if flash[:notice] %>
    <div class="mb-6 p-4 bg-primary/10 text-primary rounded-lg border border-primary/20 text-sm font-medium">
      <%= flash[:notice] %>
    </div>
  <% end %>

  <!-- Login Form -->
  <div class="bg-surface-container border border-outline-variant rounded-xl p-8 shadow-2xl">
    <%= form_with url: session_path, class: "space-y-5" do |form| %>
      <div>
        <label class="block text-sm font-medium text-on-surface-variant mb-1.5"><%= t('auth.sessions.new.email') %></label>
        <%= form.email_field :email_address,
          required: true,
          autofocus: true,
          autocomplete: "username",
          placeholder: t('auth.sessions.new.email_placeholder'),
          value: params[:email_address],
          class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder-outline text-sm" %>
      </div>

      <div>
        <label class="block text-sm font-medium text-on-surface-variant mb-1.5"><%= t('auth.sessions.new.password') %></label>
        <%= form.password_field :password,
          required: true,
          autocomplete: "current-password",
          placeholder: t('auth.sessions.new.password_placeholder'),
          maxlength: 72,
          class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-3 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder-outline text-sm" %>
      </div>

      <div>
        <%= form.submit t('auth.sessions.new.submit'),
          class: "w-full bg-primary text-on-primary font-bold py-3 px-4 rounded-lg hover:bg-primary/90 hover:shadow-lg transition-all cursor-pointer text-sm active:scale-[0.98]" %>
      </div>
    <% end %>
  </div>

  <!-- Links -->
  <div class="mt-6 flex flex-col items-center gap-3 text-sm">
    <%= link_to t('auth.sessions.new.forgot_password'), new_password_path, class: "text-on-surface-variant hover:text-primary transition-colors" %>
    <div class="text-on-surface-variant">
      <%= t('auth.sessions.new.no_account') %>
      <%= link_to t('auth.sessions.new.create_account'), new_registration_path, class: "text-primary font-semibold hover:text-primary/80 transition-colors" %>
    </div>
  </div>
</div>
