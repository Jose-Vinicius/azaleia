<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "inverse-surface": "#fafafa",
                        "inverse-on-surface": "#09090b",
                        "surface-tint": "#a78bfa",
                        "on-primary-fixed": "#2e1065",
                        "error": "#ef4444",
                        "background": "#09090b",
                        "on-primary": "#0a0012",
                        "tertiary-container": "#065f46",
                        "on-tertiary-fixed-variant": "#047857",
                        "on-primary-fixed-variant": "#5b21b6",
                        "outline": "#52525b",
                        "on-surface": "#fafafa",
                        "on-secondary-fixed-variant": "#3f3f46",
                        "surface-variant": "#18181b",
                        "surface-container-low": "#0f0f12",
                        "secondary": "#71717a",
                        "surface-dim": "#0c0c0f",
                        "surface": "#0c0c0f",
                        "on-tertiary-container": "#bbf7d0",
                        "on-background": "#fafafa",
                        "primary-container": "#7c3aed",
                        "primary": "#a78bfa",
                        "outline-variant": "#27272a",
                        "tertiary": "#34d399",
                        "surface-bright": "#18181b",
                        "surface-container-high": "#18181b",
                        "on-tertiary-fixed": "#003318",
                        "secondary-container": "#27272a",
                        "surface-container": "#121215",
                        "on-surface-variant": "#a1a1aa",
                        "on-error": "#1a0000",
                        "tertiary-fixed": "#bbf7d0",
                        "on-tertiary": "#001a12",
                        "secondary-fixed": "#a1a1aa",
                        "inverse-primary": "#5b21b6",
                        "tertiary-fixed-dim": "#6ee7b7",
                        "surface-container-lowest": "#09090b",
                        "secondary-fixed-dim": "#71717a",
                        "on-secondary-container": "#a1a1aa",
                        "on-error-container": "#fca5a5",
                        "primary-fixed": "#ede9fe",
                        "surface-container-highest": "#1e1e22",
                        "on-secondary": "#09090b",
                        "primary-fixed-dim": "#c4b5fd",
                        "on-secondary-fixed": "#18181b",
                        "on-primary-container": "#ede9fe",
                        "error-container": "#3b1111"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Geist", "sans-serif"],
                        "body": ["Geist", "sans-serif"],
                        "label": ["Geist", "sans-serif"]
                    }
                }
            }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      .kanban-column.drag-over { background-color: rgba(167, 139, 250, 0.05); border-color: rgba(167, 139, 250, 0.3); }
      .kanban-card.dragging { opacity: 0.5; transform: rotate(2deg); }
      .kanban-card { transition: transform 0.15s ease, box-shadow 0.15s ease; }
      .kanban-card:hover { transform: translateY(-1px); }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-background h-screen w-full overflow-hidden flex flex-col md:flex-row antialiased font-body selection:bg-primary-container selection:text-on-primary-container";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-background h-screen w-full overflow-hidden flex flex-col md:flex-row antialiased font-body selection:bg-primary-container selection:text-on-primary-container";
    });
  </script>
<% end %>

<%= render 'shared/sidebar' %>

<main class="flex-1 flex flex-col h-full w-full overflow-hidden bg-background relative">
  <!-- Desktop Header -->
  <header class="hidden md:flex pt-12 px-8 pb-6 flex-shrink-0 w-full justify-between items-end">
    <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90">Projetos</h2>
    <div class="flex items-center gap-3">
      <!-- Project Selector -->
      <% if @projects.any? %>
        <div class="relative" data-controller="dropdown">
          <button data-action="click->dropdown#toggle" class="flex items-center gap-2 px-4 py-2 rounded-xl bg-[#18181b] border border-[#27272a] text-on-surface hover:bg-surface-container-high transition-colors text-sm font-semibold">
            <% if @current_project&.color.present? %>
              <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= @current_project.color %>"></span>
            <% end %>
            <span><%= @current_project&.name || "Selecionar Projeto" %></span>
            <span class="material-symbols-outlined text-[16px] text-on-surface-variant">expand_more</span>
          </button>
          <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-64 bg-surface-container-high border border-outline-variant rounded-xl shadow-2xl z-[100] overflow-hidden origin-top-right">
            <div class="py-1 max-h-64 overflow-y-auto hide-scrollbar">
              <% @projects.each do |project| %>
                <a href="<%= projects_path(project_id: project.id) %>" class="flex items-center gap-3 px-4 py-3 text-sm transition-colors <%= project == @current_project ? 'text-primary bg-primary/10 font-semibold' : 'text-on-surface hover:bg-surface-container' %>">
                  <span class="w-3 h-3 rounded-full flex-shrink-0" style="background-color: <%= project.color || '#a78bfa' %>"></span>
                  <span class="truncate"><%= project.name %></span>
                  <% if project == @current_project %>
                    <span class="material-symbols-outlined text-primary text-[16px] ml-auto" style="font-variation-settings: 'FILL' 1;">check</span>
                  <% end %>
                </a>
              <% end %>
            </div>
            <div class="border-t border-outline-variant">
              <%= link_to new_project_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-2 px-4 py-3 text-sm text-on-surface-variant hover:text-primary hover:bg-surface-container transition-colors" do %>
                <span class="material-symbols-outlined text-[18px]">add</span>
                <span>Novo Projeto</span>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>

      <!-- Edit / Delete Project -->
      <% if @current_project %>
        <%= link_to edit_project_path(@current_project), data: { turbo_frame: "modal" }, class: "p-2 rounded-xl bg-[#18181b] border border-[#27272a] text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-colors flex items-center justify-center" do %>
          <span class="material-symbols-outlined text-[20px]">edit</span>
        <% end %>
      <% end %>

      <!-- Notification Bell -->
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="relative p-2 rounded-xl bg-[#18181b] border border-[#27272a] text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high transition-colors flex items-center justify-center">
          <span class="material-symbols-outlined text-[20px]">notifications</span>
          <%= render "notifications/badge" %>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-[350px] bg-surface-container-high border border-outline-variant rounded-xl shadow-2xl z-[100] overflow-hidden origin-top-right">
          <turbo-frame id="notifications_list" src="<%= notifications_path %>">
            <div class="p-6 flex items-center justify-center text-on-surface-variant gap-2 text-sm">
              <span class="material-symbols-outlined animate-spin text-[18px]">sync</span> Carregando...
            </div>
          </turbo-frame>
        </div>
      </div>
    </div>
  </header>

  <!-- Mobile Header -->
  <div class="md:hidden px-6 py-4 flex items-center justify-between">
    <h2 class="text-2xl font-headline font-bold text-on-background tracking-tight">Projetos</h2>
    <% if @projects.any? %>
      <div class="relative" data-controller="dropdown">
        <button data-action="click->dropdown#toggle" class="flex items-center gap-2 px-3 py-1.5 rounded-lg bg-[#18181b] border border-[#27272a] text-on-surface text-sm font-medium">
          <% if @current_project&.color.present? %>
            <span class="w-2.5 h-2.5 rounded-full" style="background-color: <%= @current_project.color %>"></span>
          <% end %>
          <span class="truncate max-w-[120px]"><%= @current_project&.name || "Projeto" %></span>
          <span class="material-symbols-outlined text-[14px] text-on-surface-variant">expand_more</span>
        </button>
        <div data-dropdown-target="menu" class="hidden absolute right-0 mt-2 w-56 bg-surface-container-high border border-outline-variant rounded-xl shadow-2xl z-[100] overflow-hidden">
          <div class="py-1 max-h-48 overflow-y-auto hide-scrollbar">
            <% @projects.each do |project| %>
              <a href="<%= projects_path(project_id: project.id) %>" class="flex items-center gap-3 px-4 py-2.5 text-sm transition-colors <%= project == @current_project ? 'text-primary bg-primary/10 font-semibold' : 'text-on-surface hover:bg-surface-container' %>">
                <span class="w-2.5 h-2.5 rounded-full flex-shrink-0" style="background-color: <%= project.color || '#a78bfa' %>"></span>
                <span class="truncate"><%= project.name %></span>
              </a>
            <% end %>
          </div>
          <div class="border-t border-outline-variant">
            <%= link_to new_project_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-2 px-4 py-2.5 text-sm text-on-surface-variant hover:text-primary transition-colors" do %>
              <span class="material-symbols-outlined text-[16px]">add</span>
              <span>Novo Projeto</span>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- Kanban Board -->
  <% if @projects.empty? %>
    <!-- Empty State: No Projects -->
    <div class="flex-1 flex flex-col items-center justify-center text-on-surface-variant px-6 -mt-20 md:mt-0">
      <span class="material-symbols-outlined text-[72px] mb-4 opacity-60" style="font-variation-settings: 'FILL' 0;">view_kanban</span>
      <h3 class="text-2xl font-bold text-on-surface">Nenhum projeto criado</h3>
      <p class="text-base font-medium mt-2 text-center">Crie seu primeiro projeto para organizar tarefas no Kanban.</p>
      <%= link_to new_project_path, data: { turbo_frame: "modal" }, class: "mt-6 px-6 py-2.5 bg-primary text-on-primary rounded-lg text-sm font-bold hover:bg-primary/90 transition-colors" do %>
        <span class="flex items-center gap-2">
          <span class="material-symbols-outlined text-[18px]">add</span>
          Criar Projeto
        </span>
      <% end %>
    </div>
  <% else %>
    <!-- Kanban Columns -->
    <div class="flex-1 overflow-x-auto overflow-y-hidden hide-scrollbar px-4 md:px-8 pb-6" data-controller="kanban" data-kanban-update-url-value="<%= "/tasks/:id" %>">
      <div class="flex gap-4 md:gap-6 h-full min-w-max md:min-w-0">
        <% status_config = {
          "pending" => { label: "Pendente", icon: "schedule", color: "text-amber-400", bg: "bg-amber-400/10", border: "border-amber-400/20", dot: "bg-amber-400" },
          "doing" => { label: "Fazendo", icon: "play_circle", color: "text-blue-400", bg: "bg-blue-400/10", border: "border-blue-400/20", dot: "bg-blue-400" },
          "done" => { label: "Concluído", icon: "check_circle", color: "text-emerald-400", bg: "bg-emerald-400/10", border: "border-emerald-400/20", dot: "bg-emerald-400" }
        } %>

        <% Task::STATUSES.each do |status| %>
          <% config = status_config[status] %>
          <% tasks = @tasks_by_status[status] %>
          <div class="kanban-column flex flex-col w-80 md:w-1/3 md:min-w-[280px] bg-surface-container/50 rounded-2xl border border-outline-variant/50 transition-colors duration-200"
               data-kanban-target="column"
               data-status="<%= status %>">
            <!-- Column Header -->
            <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant/30">
              <div class="flex items-center gap-2.5">
                <span class="w-2.5 h-2.5 rounded-full <%= config[:dot] %>"></span>
                <span class="text-sm font-bold text-on-surface tracking-tight"><%= config[:label] %></span>
                <span class="text-xs font-bold <%= config[:color] %> <%= config[:bg] %> px-2 py-0.5 rounded-full border <%= config[:border] %>"><%= tasks.size %></span>
              </div>
              <% if @current_project %>
                <%= link_to new_task_path(project_id: @current_project.id, status: status), data: { turbo_frame: "modal" }, class: "p-1 rounded-lg text-on-surface-variant hover:text-primary hover:bg-primary/10 transition-colors" do %>
                  <span class="material-symbols-outlined text-[18px]">add</span>
                <% end %>
              <% end %>
            </div>

            <!-- Column Body -->
            <div class="flex-1 overflow-y-auto hide-scrollbar p-3 space-y-2" data-kanban-target="dropzone" data-status="<%= status %>">
              <% if tasks.any? %>
                <% tasks.each do |task| %>
                  <%= render partial: "projects/kanban_card", locals: { task: task } %>
                <% end %>
              <% else %>
                <div class="flex flex-col items-center justify-center py-12 text-on-surface-variant/50" data-kanban-target="emptyState">
                  <span class="material-symbols-outlined text-[32px] mb-2 opacity-50"><%= config[:icon] %></span>
                  <span class="text-xs font-medium">Nenhuma tarefa</span>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>
</main>

<!-- Mobile FAB: Add Task -->
<% if @current_project %>
  <div class="md:hidden fixed bottom-6 right-4 z-50">
    <%= link_to new_task_path(project_id: @current_project.id), data: { turbo_frame: "modal" }, aria: { label: "Adicionar tarefa" }, class: "w-14 h-14 bg-primary text-on-primary rounded-full shadow-lg shadow-primary/30 flex items-center justify-center hover:bg-primary-fixed transition-all active:scale-95" do %>
      <span class="material-symbols-outlined text-2xl">add</span>
    <% end %>
  </div>
<% end %>
