<div id="task_<%= task.id %>_time_tracker" class="mt-8 pt-6 border-t border-outline-variant/30">
  <div class="flex items-center justify-between mb-2">
    <h3 class="text-sm font-bold text-on-surface uppercase tracking-wider">Progresso</h3>
    <% if task.estimated_minutes && task.estimated_minutes > 0 %>
      <div class="text-xs text-on-surface-variant font-medium group relative cursor-help flex items-center gap-1">
        <% 
           total_logged = task.time_entries.sum(:duration_minutes)
           perc = ((total_logged.to_f / task.estimated_minutes) * 100).to_i 
           bar_perc = [perc, 100].min
           is_overtime = perc > 100
        %>
        <span class="material-symbols-outlined text-[14px]">info</span>
        <span><%= perc %>%</span>
        
        <!-- Tooltip -->
        <div class="absolute bottom-full right-0 mb-2 opacity-0 group-hover:opacity-100 transition-opacity whitespace-nowrap bg-inverse-surface text-inverse-on-surface text-xs px-2 py-1 rounded pointer-events-none z-10">
          Gasto: <%= total_logged %>m / Estimado: <%= task.estimated_minutes %>m
        </div>
      </div>
    <% end %>
  </div>

  <% if task.estimated_minutes && task.estimated_minutes > 0 %>
    <!-- Progress Bar -->
    <div class="w-full h-2 bg-surface-container-high rounded-full overflow-hidden mb-4">
      <div class="h-full <%= is_overtime ? 'bg-[#21005E]' : 'bg-primary' %> transition-all duration-500" style="width: <%= bar_perc %>%;"></div>
    </div>
  <% else %>
    <p class="text-xs text-on-surface-variant mb-4">Sem tempo estimado.</p>
  <% end %>

  <!-- Add Block Form -->
  <div data-controller="time-log">
    <%= form_with model: [task, TimeEntry.new], class: "flex items-center" do |f| %>
      <%= f.hidden_field :duration_minutes, data: { time_log_target: "duration" } %>
      <button type="submit" class="w-full py-2.5 bg-surface-container-low hover:bg-surface-container-high border border-outline-variant rounded-lg text-sm font-bold text-primary transition-colors flex items-center justify-center gap-2">
        <span class="material-symbols-outlined text-[18px]">timer</span>
        Adicionar Bloco de Sessão
      </button>
    <% end %>
  </div>

  <!-- Time Entries History -->
  <% if task.time_entries.where.not(id: nil).any? %>
    <div class="mt-4 space-y-2 max-h-32 overflow-y-auto hide-scrollbar pr-1">
      <% task.time_entries.where.not(id: nil).order(created_at: :desc).each do |entry| %>
        <div class="flex items-center justify-between p-2 rounded-lg border border-outline-variant/30 hover:bg-surface-container-lowest transition-colors group">
          <div class="flex items-center gap-2">
            <span class="material-symbols-outlined text-[16px] text-on-surface-variant" style="font-variation-settings: 'FILL' 1;">timer</span>
            <span class="text-sm font-medium text-on-surface"><%= entry.duration_minutes %>m</span>
            <span class="text-xs text-on-surface-variant ml-2"><%= time_ago_in_words(entry.created_at) %> atrás</span>
          </div>
          <%= button_to task_time_entry_path(task, entry), method: :delete, class: "p-1 rounded-md text-on-surface-variant hover:text-error hover:bg-error/10 opacity-0 group-hover:opacity-100 transition-all focus:opacity-100 cursor-pointer flex items-center justify-center" do %>
             <span class="material-symbols-outlined text-[16px]">close</span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
