<% is_overdue = task.schedule_at.present? && task.schedule_at.to_date < Date.today %>
<% border_class = is_overdue ? 'border-error/30' : 'border-outline-variant' %>
<% accent_class = is_overdue ? 'bg-error' : 'bg-primary' %>
<% btn_class = is_overdue ? 'border-error/50 text-error hover:bg-error/20' : 'border-outline-variant text-primary hover:bg-primary/20' %>
<% title_class = is_overdue ? 'text-error group-hover:text-error/80' : 'text-on-background group-hover:text-primary' %>
<% date_class = is_overdue ? 'text-error/70' : 'text-on-surface-variant' %>

<div id="<%= dom_id task %>" class="group relative flex items-start gap-4 p-4 rounded-xl bg-surface-container hover:bg-surface-bright border <%= border_class %> transition-all duration-200 overflow-hidden">
  <div class="absolute inset-y-0 left-0 w-1 <%= accent_class %> opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none z-0"></div>
  
  <div class="flex-shrink-0 pt-0.5 z-10 relative">
    <%= button_to task_path(task, task: { completed: true }), method: :patch, class: "w-5 h-5 rounded-full border #{btn_class} bg-surface-container-lowest transition-colors cursor-pointer mt-[2px] flex items-center justify-center group/btn", form: { data: { turbo_frame: "_top" } } do %>
      <span class="material-symbols-outlined text-[14px] opacity-0 group-hover/btn:opacity-100 transition-opacity" style="font-variation-settings: 'FILL' 1;">check</span>
    <% end %>
  </div>

  <%= link_to task, data: { turbo_frame: "modal" }, class: "flex-1 flex flex-col sm:flex-row sm:items-center sm:justify-between outline-none before:absolute before:inset-0 before:z-0 cursor-pointer" do %>
    <div class="text-base font-medium select-none <%= title_class %> transition-colors z-10 relative">
      <%= task.title %>
    </div>
    <div class="flex items-center gap-3 mt-1 sm:mt-0 z-10 relative pointer-events-none">
      <% if task.respond_to?(:schedule_at) && task.schedule_at.present? %>
        <span class="text-sm font-medium <%= date_class %>">
          <%= task.schedule_at.to_date.strftime("%d/%m/%Y") %>
        </span>
      <% end %>
      <span class="flex items-center gap-1 text-xs font-bold text-primary bg-primary/10 px-2 py-0.5 rounded-full border border-primary/20">
        <span class="material-symbols-outlined text-[13px]">star</span>
        <%= number_with_precision(task.score, precision: 1, strip_insignificant_zeros: true) %>
      </span>
    </div>
  <% end %>
</div>