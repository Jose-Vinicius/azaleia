<%= form_with(model: task, class: "flex flex-col") do |form| %>
  <div class="p-8 space-y-6 flex-1">
    <% if task.errors.any? %>
      <div class="p-4 bg-error-container text-on-error-container rounded-lg border border-error/50">
        <h2 class="text-sm font-bold mb-2"><%= pluralize(task.errors.count, "erro") %> impediu está tarefa de ser salva:</h2>
        <ul class="list-disc pl-5 text-sm">
          <% task.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, class: "block text-sm font-medium text-on-surface-variant mb-1" %>
      <%= form.text_field :title, class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder-secondary", placeholder: "Task title" %>
    </div>

    <div>
      <%= form.label :description, class: "block text-sm font-medium text-on-surface-variant mb-1" %>
      <%= form.text_area :description, rows: 4, class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder-secondary resize-none", placeholder: "Add details..." %>
    </div>

    <div>
      <%= form.label :schedule_at, class: "block text-sm font-medium text-on-surface-variant mb-1" %>
      <%= form.date_field :schedule_at, class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all focus:outline-none", onclick: "this.showPicker()", style: "color-scheme: dark;" %>    </div>

    <div class="flex gap-4">
      <div class="flex-1">
        <%= form.label :estimated_minutes, t('activerecord.attributes.task.estimated_minutes', default: 'Tempo Estimado (min)'), class: "block text-sm font-medium text-on-surface-variant mb-1" %>
        <%= form.number_field :estimated_minutes, min: 0, step: 1, class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all placeholder-secondary", placeholder: "Ex: 120" %>
      </div>
      <div class="flex-1">
        <%= form.label :multiplier_id, t('activerecord.attributes.task.multiplier_id', default: 'Importância'), class: "block text-sm font-medium text-on-surface-variant mb-1" %>
        <%= form.collection_select :multiplier_id, Multiplier.all, :id, :name, { prompt: "Selecione..." }, class: "w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-4 py-2 text-on-surface focus:ring-2 focus:ring-primary focus:border-primary outline-none transition-all" %>
      </div>
    </div>
  </div>

  <!-- Modal Footer Actions -->
  <div class="px-6 py-6 bg-surface-container border-t border-outline-variant flex items-center justify-end gap-3 mt-auto">
    <button type="button" onclick="document.getElementById('modal').innerHTML=''" class="px-5 py-2 text-sm font-bold border border-transparent rounded-lg text-on-surface-variant hover:bg-surface-container-high transition-all">
       Cancel
    </button>
    <%= form.submit task.new_record? ? "Create Task" : "Update Task", class: "px-5 py-2 text-sm font-bold bg-primary text-on-primary rounded-lg hover:bg-primary/90 hover:shadow-lg transition-all cursor-pointer" %>
  </div>
<% end %>
