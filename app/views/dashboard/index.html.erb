<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
      
      @media (min-width: 1024px) {
        .lg\:grid-dynamic {
          grid-template-columns: repeat(var(--final-cols, 3), minmax(0, 1fr)) !important;
        }
      }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>

<%= render 'shared/sidebar' %>

<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-full w-full relative">
  <!-- Header -->
  <header class="pt-12 px-8 pb-8 flex-shrink-0 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90"><%= t('dashboard.title') %></h2>
    
    <form action="<%= dashboard_index_path %>" method="get" data-turbo-frame="_top" class="flex items-center gap-3 bg-[#18181b] border border-[#27272a] pl-3 pr-1 py-1 rounded-xl shadow-sm">
      <span class="text-xs font-semibold uppercase tracking-wider text-on-surface-variant flex items-center gap-1.5 opacity-80">
        <span class="material-symbols-outlined text-[16px]">calendar_month</span>
        Período:
      </span>
      <div class="relative">
        <select name="filter_period" onchange="this.form.submit()" class="bg-[#09090b] border border-[#27272a] text-[#fafafa] text-sm font-medium rounded-lg focus:ring-primary focus:border-primary block py-2 pl-3 pr-10 cursor-pointer hover:border-primary/50 transition-colors outline-none appearance-none">
          <option value="week" <%= 'selected' if @filter_period == 'week' %>>Semana atual</option>
          <option value="month" <%= 'selected' if @filter_period == 'month' %>>Mês atual</option>
          <option value="year" <%= 'selected' if @filter_period == 'year' %>>Ano atual</option>
        </select>
        <div class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-2 text-[#a1a1aa]">
          <span class="material-symbols-outlined text-[18px]">unfold_more</span>
        </div>
      </div>
    </form>
  </header>
  <!-- Vertical Scrolling List -->
  <div id="dashboard-grid" data-controller="grid-layout" class="flex-1 overflow-y-auto px-6 md:px-8 pb-32 md:pb-12 <%= @cards.empty? ? 'flex flex-col items-center justify-center' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-dynamic gap-6' %>">
    <% if @cards.empty? %>
      <div class="flex flex-col items-center justify-center text-on-surface-variant animate-pulse opacity-80">
        <span class="material-symbols-outlined text-[72px] mb-4" style="font-variation-settings: 'FILL' 0;">done_all</span>
        <h3 class="text-2xl font-bold text-on-surface"><%= t('dashboard.empty_state.title') %></h3>
        <p class="text-base font-medium mt-2"><%= t('dashboard.empty_state.subtitle') %>.</p>
        <%= link_to inbox_index_path, class: "mt-6 px-6 py-2.5 bg-surface-container hover:bg-surface-container-high border border-outline-variant rounded-lg text-sm font-bold text-on-surface transition-colors" do %>
          <%= t('dashboard.empty_state.button')%>
        <% end %>
      </div>
    <% else %>
      <% @cards.each do |date_card, tasks| %>
        <%= render partial: "card", locals: { date: date_card, tasks: tasks } %>
      <% end %>
    <% end %>
  </div>
  <script>

  </script>
</main>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden flex justify-between items-center h-16 px-1 pb-safe bg-zinc-950/90 backdrop-blur-lg fixed bottom-0 w-full z-50 border-t border-zinc-800 shadow-2xl">
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= inbox_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">inbox</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Inbox</span>
  </a>
  <a class="flex flex-col items-center justify-center text-violet-400 scale-105 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full relative" href="#">
    <div class="absolute -top-1 w-8 h-1 bg-violet-400 rounded-b-full"></div>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 1;">dashboard</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Dashboard</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= metrics_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">bar_chart</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Métricas</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= history_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">history</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Histórico</span>
  </a>
  <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" do %>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">settings</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Settings</span>
  <% end %>
</nav>