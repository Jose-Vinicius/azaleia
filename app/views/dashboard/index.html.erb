<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>

<!-- Desktop Side Navigation -->
<nav class="hidden md:flex flex-col h-full py-6 bg-zinc-950 h-screen w-64 border-r border-zinc-800 flex-shrink-0 z-10">
  <div class="px-6">
    <h1 class="text-xl font-black text-zinc-50 tracking-tighter">Azaleia</h1>
    <p class="font-sans text-sm font-medium text-zinc-500 mt-1"><br></p>
  </div>
  <div class="px-4 mb-6">
    <%= link_to new_task_path, class: "w-full bg-primary hover:bg-primary-container text-on-primary font-medium py-2 px-4 rounded-lg flex items-center justify-center gap-2 transition-colors" do %>
      <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 0;">add</span>
      Add Task
    <% end %>
  </div>
  <div class="flex-1 flex flex-col gap-1 px-2">
    <!-- Inbox (Inactive) -->
    <a class="text-zinc-400 hover:bg-zinc-900/50 hover:text-zinc-200 flex items-center gap-3 px-4 py-3 transition-all rounded-md font-sans text-sm font-medium cursor-pointer duration-200 hover:bg-zinc-800/50" href="<%= inbox_index_path %>">
      <span class="material-symbols-outlined" data-icon="inbox" style="font-variation-settings: 'FILL' 0;">inbox</span>
      Inbox
    </a>
    <!-- Dashboard (Active) -->
    <a class="bg-zinc-900 text-violet-400 border-l-2 border-violet-400 flex items-center gap-3 px-4 py-3 rounded-r-md font-sans text-sm font-medium cursor-pointer transition-colors duration-200" href="#">
      <span class="material-symbols-outlined" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
      Dashboard
    </a>
  </div>
</nav>

<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-full w-full relative">
  <!-- Header -->
  <header class="pt-12 px-8 pb-8 flex-shrink-0">
    <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90">Dashboard</h2>
  </header>
  <!-- Vertical Scrolling List -->
  <div class="flex-1 overflow-y-auto px-8 pb-20 md:pb-12 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    <% @cards.each do |date_card, tasks| %>
      <%= render partial: "card", locals: { date: date_card, tasks: tasks } %>
    <% end %>
  </div>
</main>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden flex justify-around items-center h-16 px-4 pb-safe bg-zinc-950/90 backdrop-blur-lg fixed bottom-0 w-full z-50 border-t border-zinc-800 shadow-2xl">
  <!-- Inbox (Inactive) -->
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform active:bg-zinc-900 w-16 h-full" href="<%= inbox_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-1" data-icon="inbox" style="font-variation-settings: 'FILL' 0;">inbox</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Inbox</span>
  </a>
  <!-- Dashboard (Active) -->
  <a class="flex flex-col items-center justify-center text-violet-400 scale-110 tap-highlight-transparent active:scale-90 transition-transform active:bg-zinc-900 w-16 h-full relative" href="#">
    <div class="absolute -top-1 w-8 h-1 bg-violet-400 rounded-b-full"></div>
    <span class="material-symbols-outlined text-2xl mb-1" data-icon="dashboard" style="font-variation-settings: 'FILL' 1;">dashboard</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Dashboard</span>
  </a>
</nav>