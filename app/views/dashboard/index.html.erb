<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      
      @media (min-width: 1024px) {
        .lg\:grid-dynamic {
          grid-template-columns: repeat(var(--final-cols, 3), minmax(0, 1fr)) !important;
        }
      }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>

<!-- Desktop Side Navigation -->
<nav class="hidden md:flex flex-col h-screen sticky left-0 top-0 w-64 bg-[#09090b] border-r border-[#27272a] font-['Geist'] tracking-tight flex-shrink-0 z-50">
  <div class="flex items-center">
    <%= image_tag "logo.png", class: "w-24 h-24 object-contain" %>
    <h2 class="text-xl font-black text-[#fafafa] tracking-tighter">Azaleia</h2>
  </div>
    <p class="text-xs text-on-surface-variant font-medium tracking-wide mt-1 uppercase"></p>
  </div>
  <div class="px-4 py-2">
    <%= link_to new_task_path, data: { turbo_frame: "modal" }, class: "w-full flex items-center justify-center gap-2 bg-primary text-on-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98] shadow-[0_0_0_1px_rgba(167,139,250,0.1)]" do %>
      <span class="material-symbols-outlined text-sm" data-icon="add">add</span>
      <%= t('layouts.side_bar.add_task')%>
    <% end %>
  </div>
  <div class="flex-1 flex flex-col px-3 py-2 space-y-1">
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= inbox_index_path %>">
      <span class="material-symbols-outlined" data-icon="inbox">inbox</span>
      <span>Inbox</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a78bfa] bg-[#18181b] border-r-2 border-[#a78bfa] font-semibold transition-all duration-150 active:scale-[0.98]" href="<%= dashboard_index_path %>">
      <span class="material-symbols-outlined" data-icon="dashboard" data-weight="fill" style='font-variation-settings: "FILL" 1;'>dashboard</span>
      <span>Dashboard</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= history_index_path %>">
      <span class="material-symbols-outlined" data-icon="history">history</span>
      <span>Histórico</span>
    </a>
    <div class="flex-1"></div>
    <!-- User Account Dropdown -->
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98] text-left">
        <span class="material-symbols-outlined text-[20px]">account_circle</span>
        <span class="text-sm truncate flex-1"><%= Current.user&.email_address %></span>
        <span class="material-symbols-outlined text-[16px]">expand_more</span>
      </button>
      <div data-dropdown-target="menu" class="hidden absolute bottom-full left-3 right-3 mb-1 bg-[#18181b] border border-[#27272a] rounded-lg shadow-xl overflow-hidden z-50">
        <%= button_to session_path, method: :delete, form: { data: { turbo: false } }, class: "w-full flex items-center gap-3 px-4 py-3 text-sm text-[#fca5a5] hover:bg-[#27272a] transition-colors text-left" do %>
          <span class="material-symbols-outlined text-[18px]">logout</span>
          <span>Sair da Conta</span>
        <% end %>
      </div>
    </div>
    <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" do %>
      <span class="material-symbols-outlined">settings</span>
      <span><%= t('layouts.side_bar.settings')%></span>
    <% end %>
  </div>
</nav>

<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-full w-full relative">
  <!-- Header -->
  <header class="pt-12 px-8 pb-8 flex-shrink-0">
    <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90"><%= t('dashboard.title') %></h2>
  </header>
  <!-- Vertical Scrolling List -->
  <div id="dashboard-grid" data-controller="grid-layout" class="flex-1 overflow-y-auto px-6 md:px-8 pb-32 md:pb-12 <%= @cards.empty? ? 'flex flex-col items-center justify-center' : 'grid grid-cols-1 md:grid-cols-2 lg:grid-dynamic gap-6' %>">
    <% if @cards.empty? %>
      <div class="flex flex-col items-center justify-center text-on-surface-variant animate-pulse opacity-80">
        <span class="material-symbols-outlined text-[72px] mb-4" style="font-variation-settings: 'FILL' 0;">done_all</span>
        <h3 class="text-2xl font-bold text-on-surface"><%= t('dashboard.empty_state.title') %></h3>
        <p class="text-base font-medium mt-2"><%= t('dashboard.empty_state.subtitle') %>.</p>
        <%= link_to inbox_index_path, class: "mt-6 px-6 py-2.5 bg-surface-container hover:bg-surface-container-high border border-outline-variant rounded-lg text-sm font-bold text-on-surface transition-colors" do %>
          <%= t('dashboard.empty_state.button')%>
        <% end %>
      </div>
    <% else %>
      <% @cards.each do |date_card, tasks| %>
        <%= render partial: "card", locals: { date: date_card, tasks: tasks } %>
      <% end %>
    <% end %>
  </div>
  <script>
    (function() {
      const grid = document.getElementById("dashboard-grid");
      if (grid) {
        const savedCols = parseInt(localStorage.getItem("dashboardCols") || "3", 10);
        grid.style.setProperty("--final-cols", Math.min(savedCols, Math.max(1, grid.children.length)));
      }
      // Show/hide completed tasks and empty day cards
      function applyCompletedVisibility() {
        const show = localStorage.getItem("showCompletedOnDashboard") === "true";
        document.querySelectorAll(".dashboard-completed-task").forEach(el => {
          el.style.display = show ? "" : "none";
        });
        // Hide day cards that have no visible tasks
        document.querySelectorAll("[data-dashboard-card]").forEach(card => {
          const allTasks = card.querySelectorAll("[data-task-item]");
          const visibleTasks = Array.from(allTasks).filter(t => t.style.display !== "none");
          card.style.display = visibleTasks.length === 0 ? "none" : "";
        });
        // Update grid cols based on visible cards
        if (grid) {
          const visibleCards = grid.querySelectorAll("[data-dashboard-card]:not([style*='display: none'])");
          const savedCols = parseInt(localStorage.getItem("dashboardCols") || "3", 10);
          grid.style.setProperty("--final-cols", Math.min(savedCols, Math.max(1, visibleCards.length)));
        }
      }
      applyCompletedVisibility();
      window.addEventListener("settings:updated", applyCompletedVisibility);
    })();
  </script>
</main>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden flex justify-around items-center h-16 px-2 pb-safe bg-zinc-950/90 backdrop-blur-lg fixed bottom-0 w-full z-50 border-t border-zinc-800 shadow-2xl">
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform w-16 h-full" href="<%= inbox_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">inbox</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Inbox</span>
  </a>
  <a class="flex flex-col items-center justify-center text-violet-400 scale-105 tap-highlight-transparent active:scale-90 transition-transform w-16 h-full relative" href="#">
    <div class="absolute -top-1 w-8 h-1 bg-violet-400 rounded-b-full"></div>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 1;">dashboard</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Dashboard</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform w-16 h-full" href="<%= history_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">history</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Histórico</span>
  </a>
  <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform w-16 h-full" do %>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">settings</span>
    <span class="text-[10px] font-medium tracking-wide uppercase">Settings</span>
  <% end %>
</nav>