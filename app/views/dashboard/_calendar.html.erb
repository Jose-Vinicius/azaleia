<%
  today = Date.today
  if @filter_period == 'week'
    start_date = today.beginning_of_week(:sunday)
    end_date = today.end_of_week(:sunday)
  else
    # Mês ou ano foca na visualização mensal do mês atual para evitar grids colossais
    start_date = today.beginning_of_month.beginning_of_week(:sunday)
    end_date = today.end_of_month.end_of_week(:sunday)
  end
  date_range = (start_date..end_date).to_a
  
  weekdays = ['Dom', 'Seg', 'Ter', 'Qua', 'Qui', 'Sex', 'Sáb']
%>

<div class="w-full h-full bg-surface-container border border-outline-variant rounded-xl flex flex-col overflow-hidden shadow-sm">
  <!-- Weekdays Header -->
  <div class="grid grid-cols-7 border-b border-outline-variant bg-surface-container-high/50">
    <% weekdays.each do |day| %>
      <div class="py-3 text-center text-xs font-semibold text-on-surface-variant uppercase tracking-wider">
        <%= day %>
      </div>
    <% end %>
  </div>

  <!-- Calendar Grid -->
  <div class="flex-1 grid grid-cols-7 auto-rows-fr bg-outline-variant gap-px">
    <% date_range.each do |date| %>
      <%
        is_today = date == today
        is_current_month = date.month == today.month
        day_tasks = tasks_by_date[date] || []
      %>
      <div class="group/day flex flex-col p-2 min-h-[120px] transition-colors <%= is_today ? 'bg-primary/5 hover:bg-primary/10' : 'bg-surface-container hover:bg-surface-container-high/50' %>">
        <div class="flex items-center justify-between mb-1.5">
          <span class="text-sm font-semibold <%= is_today ? 'text-primary bg-primary/20 w-7 h-7 rounded-full flex items-center justify-center' : (is_current_month || @filter_period == 'week' ? 'text-on-surface ml-1' : 'text-on-surface-variant/50 ml-1') %>">
            <%= date.day %>
          </span>
          <% if date >= today %>
            <%= link_to new_task_path(schedule_at: date), data: { turbo_frame: "modal" }, class: "opacity-100 md:opacity-0 group-hover/day:opacity-100 focus:opacity-100 text-on-surface-variant hover:text-primary transition-opacity p-1 rounded hover:bg-surface-variant" do %>
              <span class="material-symbols-outlined text-[16px] block">add</span>
            <% end %>
          <% end %>
        </div>
        
        <div class="flex-1 flex flex-col gap-1.5 overflow-y-auto hide-scrollbar">
          <% day_tasks.each do |task| %>
            <%= link_to edit_task_path(task), data: { turbo_frame: "modal" }, class: "group relative flex items-center gap-1.5 px-2 py-1.5 rounded-md transition-colors #{task.completed ? 'bg-surface-container-lowest/50 opacity-60' : 'bg-surface-container-high hover:bg-surface-bright border border-transparent hover:border-outline-variant'}" do %>
              <% color_class = task.completed ? 'bg-tertiary text-on-tertiary-fixed-variant' : (task.score >= 5 ? 'bg-error text-on-error' : (task.score >= 3 ? 'bg-[#f59e0b] text-[#78350f]' : 'bg-primary text-on-primary')) %>
              <div class="w-2 h-2 rounded-full flex-shrink-0 <%= color_class %>" title="<%= task.completed ? 'Concluída' : 'Prioridade ' + task.score.to_i.to_s %>"></div>
              <span class="text-xs truncate flex-1 font-medium <%= task.completed ? 'line-through text-on-surface-variant' : 'text-on-surface-variant group-hover:text-on-surface' %>">
                <%= task.title %>
              </span>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
