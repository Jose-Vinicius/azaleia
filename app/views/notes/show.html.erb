<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" data-controller="modal" data-action="click->modal#closeBackground">
    <div class="relative w-full max-w-2xl max-h-[90vh] bg-background border border-outline-variant rounded-xl shadow-2xl overflow-hidden flex flex-col" data-modal-target="container">
      <!-- Modal Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant shrink-0">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="edit_document">edit_document</span>
          <span class="text-xs font-bold uppercase tracking-widest text-on-surface-variant line-clamp-1"><%= @note.title %></span>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to edit_note_path(@note), class: "p-1 hover:bg-surface-container-high rounded transition-colors text-on-surface-variant hover:text-primary" do %>
            <span class="material-symbols-outlined" data-icon="edit">edit</span>
          <% end %>
          <button onclick="document.getElementById('modal').innerHTML=''" class="p-1 hover:bg-surface-container-high rounded transition-colors text-on-surface-variant">
            <span class="material-symbols-outlined" data-icon="close">close</span>
          </button>
        </div>
      </div>

      <!-- Modal Body (Markdown Content) -->
      <div class="p-6 overflow-y-auto flex-1 custom-scrollbar">
        <h1 class="text-2xl font-bold mb-6 text-on-surface"><%= @note.title %></h1>
        <div class="prose prose-invert prose-sm md:prose-base max-w-none prose-a:text-primary hover:prose-a:text-primary-fixed">
          <%= markdown(@note.description) %>
        </div>
      </div>
      
      <!-- Modal Footer -->
      <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-lowest shrink-0 flex justify-between items-center text-xs text-on-surface-variant">
        <span>Criado em <%= @note.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
        <% if @note.updated_at > @note.created_at %>
          <span>Editado em <%= @note.updated_at.strftime("%d/%m/%Y às %H:%M") %></span>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
