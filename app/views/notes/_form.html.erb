<%= form_with(model: note, class: "flex flex-col h-full") do |form| %>
  <div class="p-6 overflow-y-auto flex-1 custom-scrollbar space-y-6">
    <% if note.errors.any? %>
      <div class="bg-error/10 border border-error/20 text-error px-4 py-3 rounded-lg" role="alert">
        <ul class="list-disc pl-5 text-sm">
          <% note.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :title, "Título", class: "block text-sm font-semibold mb-2 text-on-surface-variant" %>
      <%= form.text_field :title, class: "w-full bg-surface-container-high border border-outline-variant text-on-surface text-sm rounded-lg focus:ring-primary focus:border-primary block p-2.5 transition-colors placeholder-on-surface-variant/50", placeholder: "Título da anotação", required: true %>
    </div>

    <div>
      <div class="flex justify-between items-center mb-2">
        <%= form.label :description, "Descrição (suporta Markdown)", class: "block text-sm font-semibold text-on-surface-variant" %>
      </div>
      <%= form.text_area :description, rows: 10, class: "w-full bg-surface-container-high border border-outline-variant text-on-surface text-sm rounded-lg focus:ring-primary focus:border-primary block p-2.5 transition-colors placeholder-on-surface-variant/50 custom-scrollbar font-mono", placeholder: "Escreva sua anotação aqui..." %>
    </div>
  </div>

  <div class="px-6 py-4 border-t border-outline-variant bg-surface-container-lowest shrink-0 flex justify-end gap-3">
    <button type="button" onclick="document.getElementById('modal').innerHTML=''" class="px-4 py-2 text-sm font-semibold text-on-surface-variant hover:text-on-surface hover:bg-surface-container-high rounded-lg transition-colors">
      Cancelar
    </button>
    <%= form.submit "Salvar Anotação", class: "px-4 py-2 text-sm font-semibold bg-primary text-on-primary rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98] cursor-pointer" %>
  </div>
<% end %>
