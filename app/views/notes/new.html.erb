<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" data-controller="modal" data-action="click->modal#closeBackground">
    <div class="relative w-full max-w-2xl max-h-full bg-background border border-outline-variant rounded-xl shadow-2xl overflow-hidden flex flex-col" data-modal-target="container">
      <!-- Modal Header -->
      <div class="flex items-center justify-between px-6 py-4 border-b border-outline-variant shrink-0">
        <div class="flex items-center gap-3">
          <span class="material-symbols-outlined text-primary" data-icon="edit_document">edit_document</span>
          <span class="text-xs font-bold uppercase tracking-widest text-on-surface-variant">Nova Anotação</span>
        </div>
        <button onclick="document.getElementById('modal').innerHTML=''" class="p-1 hover:bg-surface-container-high rounded transition-colors text-on-surface-variant">
          <span class="material-symbols-outlined" data-icon="close">close</span>
        </button>
      </div>

      <!-- Modal Body (Form) -->
      <%= render "form", note: @note %>
      
    </div>
  </div>
<% end %>
