<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries,typography"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
      
      @media (min-width: 1024px) {
        .lg\:grid-dynamic {
          grid-template-columns: repeat(var(--final-cols, 3), minmax(0, 1fr)) !important;
        }
      }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>

<%= render 'shared/sidebar' %>

<main class="flex-1 flex flex-col h-full w-full relative">
  <header class="pt-12 px-8 pb-8 flex-shrink-0 flex flex-col md:flex-row md:items-end justify-between gap-4">
    <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90">Anotações</h2>
    
    <div class="flex items-center gap-4">
      <%= link_to new_note_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-2 bg-primary text-on-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98]" do %>
        <span class="material-symbols-outlined text-sm">add</span>
        Nova Anotação
      <% end %>
    </div>
  </header>

  <turbo-frame id="notes_list" class="flex-1 flex flex-col h-full w-full overflow-hidden">
    <div class="flex-1 overflow-y-auto px-6 md:px-8 pb-32 md:pb-12">
      <% if @notes.empty? %>
        <div class="flex flex-col items-center justify-center text-on-surface-variant h-full opacity-80">
          <span class="material-symbols-outlined text-[72px] mb-4" style="font-variation-settings: 'FILL' 0;">edit_document</span>
          <h3 class="text-2xl font-bold text-on-surface">Nenhuma Anotação</h3>
          <p class="text-base font-medium mt-2">Crie sua primeira anotação para começar.</p>
        </div>
      <% else %>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          <% @notes.each do |note| %>
            <div class="bg-[#18181b] border border-[#27272a] rounded-xl p-5 hover:border-primary/50 transition-colors flex flex-col h-64">
              <div class="flex justify-between items-start mb-2">
                <h3 class="text-lg font-bold text-[#fafafa] line-clamp-1"><%= note.title %></h3>
                <div class="flex gap-1 ml-2 shrink-0">
                  <%= link_to edit_note_path(note), data: { turbo_frame: "modal" }, class: "text-on-surface-variant hover:text-primary transition-colors p-1" do %>
                    <span class="material-symbols-outlined text-[18px]">edit</span>
                  <% end %>
                  <%= button_to note_path(note), method: :delete, form: { data: { turbo_confirm: "Tem certeza que deseja excluir esta anotação?" } }, class: "text-on-surface-variant hover:text-error transition-colors p-1" do %>
                    <span class="material-symbols-outlined text-[18px]">delete</span>
                  <% end %>
                </div>
              </div>
              <div class="text-sm text-on-surface-variant flex-1 overflow-hidden prose prose-invert prose-sm max-w-none">
                <%= markdown(note.description) %>
              </div>
              <div class="text-xs text-[#71717a] mt-4 shrink-0 flex justify-between items-center border-t border-[#27272a] pt-3">
                <span><%= note.created_at.strftime("%d/%m/%Y às %H:%M") %></span>
                <%= link_to "Ler tudo", note_path(note), data: { turbo_frame: "modal" }, class: "text-primary hover:underline font-medium" %>
              </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </turbo-frame>
</main>
