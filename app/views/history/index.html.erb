<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>


<!-- Desktop Side Navigation -->
<nav class="hidden md:flex flex-col h-screen sticky left-0 top-0 w-64 bg-[#09090b] border-r border-[#27272a] font-['Geist'] tracking-tight flex-shrink-0 z-50">
  <div class="flex items-center">
    <%= image_tag "logo.png", class: "w-24 h-24 object-contain" %>
    <h2 class="text-xl font-black text-[#fafafa] tracking-tighter">Azaleia</h2>
  </div>
    <p class="text-xs text-on-surface-variant font-medium tracking-wide mt-1 uppercase"></p>
  </div>
  <div class="px-4 py-2">
    <%= link_to new_task_path, data: { turbo_frame: "modal" }, class: "w-full flex items-center justify-center gap-2 bg-primary text-on-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98] shadow-[0_0_0_1px_rgba(167,139,250,0.1)]" do %>
      <span class="material-symbols-outlined text-sm" data-icon="add">add</span>
      <%= t('layouts.side_bar.add_task')%>
    <% end %>
  </div>
  <div class="flex-1 flex flex-col px-3 py-2 space-y-1">
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= inbox_index_path %>">
      <span class="material-symbols-outlined" data-icon="inbox">inbox</span>
      <span>Inbox</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= dashboard_index_path %>">
      <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
      <span>Dashboard</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= metrics_path %>">
      <span class="material-symbols-outlined" data-icon="bar_chart">bar_chart</span>
      <span>Métricas</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a78bfa] bg-[#18181b] border-r-2 border-[#a78bfa] font-semibold transition-all duration-150 active:scale-[0.98]" href="<%= history_index_path %>">
      <span class="material-symbols-outlined" data-icon="history" data-weight="fill" style='font-variation-settings: "FILL" 1;'>history</span>
      <span>Histórico</span>
    </a>
    <div class="flex-1"></div>
    <!-- User Account Dropdown -->
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98] text-left">
        <span class="material-symbols-outlined text-[20px]">account_circle</span>
        <span class="text-sm truncate flex-1"><%= Current.user&.email_address %></span>
        <span class="material-symbols-outlined text-[16px]">expand_more</span>
      </button>
      <div data-dropdown-target="menu" class="hidden absolute bottom-full left-3 right-3 mb-1 bg-[#18181b] border border-[#27272a] rounded-lg shadow-xl overflow-hidden z-50">
        <%= button_to session_path, method: :delete, form: { data: { turbo: false } }, class: "w-full flex items-center gap-3 px-4 py-3 text-sm text-[#fca5a5] hover:bg-[#27272a] transition-colors text-left" do %>
          <span class="material-symbols-outlined text-[18px]">logout</span>
          <span>Sair da Conta</span>
        <% end %>
      </div>
    </div>
    <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" do %>
      <span class="material-symbols-outlined">settings</span>
      <span><%= t('layouts.side_bar.settings')%></span>
    <% end %>
  </div>
</nav>

<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-full w-full relative">
  <!-- Desktop Header -->
  <header class="hidden md:block pt-12 px-8 pb-8 flex-shrink-0">
    <div class="flex items-center justify-between">
      <h2 class="text-3xl md:text-3xl font-black tracking-tighter text-on-surface uppercase opacity-90"><%= t('history.header_title') %></h2>
      <% completed_count = @tasks.count { |t| t.completed == true } %>
      <% uncompleted_count = @tasks.count { |t| t.completed == false } %>
      <div class="flex items-center gap-3">
        <span class="flex items-center gap-1.5 text-xs font-bold text-tertiary bg-tertiary/10 px-3 py-1.5 rounded-full border border-tertiary/20">
          <span class="material-symbols-outlined text-[14px]">check_circle</span>
          <%= completed_count %> <%= t('history.completed') %>
        </span>
        <span class="flex items-center gap-1.5 text-xs font-bold text-error bg-error/10 px-3 py-1.5 rounded-full border border-error/20">
          <span class="material-symbols-outlined text-[14px]">cancel</span>
          <%= uncompleted_count %> <%= t('history.discarded') %>
        </span>
      </div>
    </div>
  </header>

  <!-- Task History List -->
  <div class="flex-1 overflow-y-auto hide-scrollbar px-6 md:px-8 pb-32 md:pb-12 w-full <%= @tasks.empty? ? 'flex flex-col items-center justify-center' : 'space-y-1' %>" id="history-list">
    <!-- Mobile Title -->
    <h2 class="md:hidden text-2xl font-headline font-bold text-on-background tracking-tight py-4 mb-2"><%= t('history.title') %></h2>

    <% if @tasks.empty? %>
      <div class="flex flex-col items-center justify-center text-on-surface-variant animate-pulse opacity-80 h-full -mt-20 md:mt-0">
        <span class="material-symbols-outlined text-[72px] mb-4" style="font-variation-settings: 'FILL' 0;">history</span>
        <h3 class="text-2xl font-bold text-on-surface"><%= t('history.empty_state.title') %></h3>
        <p class="text-base font-medium mt-2"><%= t('history.empty_state.subtitle') %></p>
        <%= link_to dashboard_index_path, class: "mt-6 px-6 py-2.5 bg-surface-container hover:bg-surface-container-high border border-outline-variant rounded-lg text-sm font-bold text-on-surface transition-colors" do %>
          <%= t('history.go_to_dashboard') %>
        <% end %>
      </div>
    <% else %>
      <% @tasks.each do |task| %>
        <% is_completed = task.completed == true %>
        <div class="group relative flex items-start gap-3 p-4 rounded-xl bg-surface-container hover:bg-surface-bright border border-outline-variant transition-all duration-200 overflow-hidden">
          <%# Status icon %>
          <% if is_completed %>
            <%= button_to task_path(task, task: { completed: nil }), method: :patch, class: "z-10 relative flex-shrink-0 mt-0.5", form: { data: { turbo_frame: "_top" } } do %>
              <span class="w-6 h-6 rounded-full bg-tertiary/15 border border-tertiary/30 flex items-center justify-center group-hover:bg-tertiary/25 transition-colors">
                <span class="material-symbols-outlined text-tertiary text-[14px]" style="font-variation-settings: 'FILL' 1;">check</span>
              </span>
            <% end %>
          <% else %>
            <%= button_to task_path(task, task: { completed: nil }), method: :patch, class: "z-10 relative flex-shrink-0 mt-0.5", form: { data: { turbo_frame: "_top" } } do %>
              <span class="w-6 h-6 rounded-full bg-error/15 border border-error/30 flex items-center justify-center group-hover:bg-error/25 transition-colors cursor-pointer">
                <span class="material-symbols-outlined text-error text-[14px]" style="font-variation-settings: 'FILL' 1;">close</span>
              </span>
            <% end %>
          <% end %>

          <%# Content area %>
          <%= link_to task, data: { turbo_frame: "modal" }, class: "flex-1 outline-none before:absolute before:inset-0 before:z-0 min-w-0" do %>
            <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-1 sm:gap-3">
              <p class="text-sm font-medium leading-tight relative z-10 truncate <%= is_completed ? 'text-on-surface' : 'text-on-surface-variant line-through' %>">
                <%= task.title %>
              </p>
              <div class="flex items-center gap-1.5 z-10 relative shrink-0">
                <span class="flex items-center gap-0.5 text-[10px] font-bold text-primary bg-primary/10 px-1.5 py-0.5 rounded-full border border-primary/20">
                  <span class="material-symbols-outlined text-[10px]">star</span>
                  <%= number_with_precision(task.score, precision: 1, strip_insignificant_zeros: true) %>
                </span>
                <span class="text-[10px] font-medium uppercase tracking-wider px-1.5 py-0.5 rounded-full <%= is_completed ? 'text-tertiary bg-tertiary/10 border border-tertiary/20' : 'text-error bg-error/10 border border-error/20' %>">
                  <%= is_completed ? t('history.status_completed') : t('history.status_discarded') %>
                </span>
              </div>
            </div>
            <div class="flex items-center gap-2 mt-1">
              <span class="text-[11px] text-on-surface-variant/60 relative z-10">
                <%= time_ago_in_words(task.completed_at || task.updated_at) %> <%= t('history.time_ago') %>
              </span>
              <% if task.schedule_at.present? %>
                <span class="text-[11px] text-on-surface-variant/40 relative z-10 flex items-center gap-0.5">
                  <span class="material-symbols-outlined text-[11px]">calendar_today</span>
                  <%= task.schedule_at.strftime("%d/%m") %>
                </span>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
</main>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden flex justify-between items-center h-16 px-1 pb-safe bg-zinc-950/90 backdrop-blur-lg fixed bottom-0 w-full z-50 border-t border-zinc-800 shadow-2xl">
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= inbox_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">inbox</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Inbox</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= dashboard_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">dashboard</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Dashboard</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= metrics_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">bar_chart</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Métricas</span>
  </a>
  <a class="flex flex-col items-center justify-center text-violet-400 scale-105 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full relative" href="#">
    <div class="absolute -top-1 w-8 h-1 bg-violet-400 rounded-b-full"></div>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 1;">history</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Histórico</span>
  </a>
  <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" do %>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">settings</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Settings</span>
  <% end %>
</nav>
