<%= turbo_frame_tag "notifications_list" do %>
  <div class="flex items-center justify-between px-4 py-3 border-b border-outline-variant shrink-0 bg-surface">
    <h3 class="text-sm font-bold text-on-surface">Notificações</h3>
    <% if @notifications.any?(&:unread?) %>
      <%= button_to "Marcar todas como lidas", mark_all_as_read_notifications_path, method: :patch, form: { data: { turbo_stream: true } }, class: "text-xs font-medium text-primary hover:text-primary/80 transition-colors" %>
    <% end %>
  </div>
  
  <div class="max-h-[300px] overflow-y-auto overscroll-contain">
    <% if @notifications.empty? %>
      <div class="p-6 text-center text-on-surface-variant text-sm">
        Nenhuma notificação por aqui.
      </div>
    <% else %>
      <ul class="divide-y divide-outline-variant/50">
        <% @notifications.each do |notification| %>
          <li id="<%= dom_id(notification) %>" class="px-4 py-3 flex items-start gap-3 transition-colors <%= notification.unread? ? 'bg-primary/5' : 'bg-surface' %>">
            <div class="w-8 h-8 rounded-full bg-surface-container-high flex items-center justify-center text-on-surface-variant shrink-0 mt-0.5">
              <span class="material-symbols-outlined text-[18px]">notifications</span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-on-surface"><%= notification.message %></p>
              <p class="text-xs text-on-surface-variant mt-1"><%= time_ago_in_words(notification.created_at) %> atrás</p>
            </div>
            <% if notification.unread? %>
              <%= button_to notification_path(notification), method: :patch, form: { data: { turbo_stream: true } }, title: "Marcar como lida", class: "p-1 rounded-lg hover:bg-surface-container-highest transition-colors text-on-surface-variant shrink-0 flex items-center justify-center" do %>
                <span class="material-symbols-outlined text-[18px]">done</span>
              <% end %>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% end %>
  </div>
<% end %>
