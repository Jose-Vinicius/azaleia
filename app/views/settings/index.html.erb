<%= turbo_frame_tag "modal" do %>
  <div class="fixed inset-0 z-50 flex items-center justify-center bg-black/50 backdrop-blur-sm p-4" data-controller="settings">
    <div class="relative w-full max-w-2xl bg-surface-container border border-outline-variant rounded-xl shadow-2xl overflow-hidden flex flex-col max-h-[85vh]">
      <!-- TopAppBar -->
      <header class="flex justify-between items-center px-6 h-16 w-full bg-zinc-950 border-b border-zinc-800 font-headline tracking-tight shrink-0">
        <div class="flex items-center gap-3">
          <span class="text-primary material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">settings</span>
          <h1 class="text-lg font-bold text-on-surface"><%= t('settings.title')%></h1>
        </div>
        <button data-action="click->settings#close" class="text-on-surface-variant hover:text-on-surface hover:bg-zinc-900 transition-colors p-2 rounded-lg">
          <span class="material-symbols-outlined" data-icon="close">close</span>
        </button>
      </header>

      <!-- Content Area -->
      <div class="flex-1 overflow-y-auto p-8 space-y-12 bg-background">
        <!-- Inbox Settings Section -->
        <section class="space-y-6 opacity-50 pointer-events-none">
          <div class="space-y-1">
            <h2 class="text-lg font-bold tracking-tight text-on-surface"><%= t('settings.inbox.title')%></h2>
            <p class="text-sm text-on-surface-variant"><%= t('settings.inbox.subtitle')%></p>
          </div>
          <div class="p-4 bg-surface-container border border-outline-variant rounded-lg text-center text-sm font-medium text-on-surface-variant">
            <%= t('settings.no_content')%>
          </div>
        </section>

        <!-- Dashboard Settings Section -->
        <section class="space-y-6">
          <div class="space-y-1">
            <h2 class="text-lg font-bold tracking-tight text-on-surface"><%= t('settings.dashboard.title')%></h2>
            <p class="text-sm text-on-surface-variant"><%= t('settings.dashboard.subtitle')%></p>
          </div>
          <div class="grid grid-cols-1 gap-4">
            <!-- Text Input: Card Limit -->
            <div class="space-y-2">
              <label class="block text-sm font-medium text-on-surface" for="card-limit"><%= t('settings.dashboard.grid.cards_per_row')%></label>
              <input data-settings-target="dashboardCols" type="number" min="3" max="7" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg text-sm text-on-surface px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none" id="card-limit" placeholder="<%= t('settings.dashboard.grid.exemplo')%>" value="3"/>
              <p class="text-xs text-on-surface-variant"><%= t('settings.dashboard.grid.description')%></p>
            </div>
            
            <!-- Text Input: Pomodoro Block -->
            <div class="space-y-2 mt-4">
              <label class="block text-sm font-medium text-on-surface" for="block-size"><%= t('settings.dashboard.pomodoro.title') %></label>
              <input data-settings-target="pomodoroBlock" type="number" min="5" max="180" step="5" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg text-sm text-on-surface px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all" id="block-size" placeholder="Ex.: 30" value="30"/>
              <p class="text-xs text-on-surface-variant"><%= t('settings.dashboard.pomodoro.description') %></p>
            </div>

          </div>
        </section>

        <!-- Account Section -->
        <section class="space-y-6">
          <div class="space-y-1">
            <h2 class="text-lg font-bold tracking-tight text-on-surface"><%= t('settings.account.title') %></h2>
            <p class="text-sm text-on-surface-variant"><%= t('settings.account.subtitle') %></p>
          </div>
          <div class="flex items-center justify-between p-4 bg-surface-container border border-outline-variant rounded-lg">
            <div class="flex items-center gap-3 min-w-0">
              <span class="material-symbols-outlined text-on-surface-variant text-[20px]">account_circle</span>
              <span class="text-sm font-medium text-on-surface truncate"><%= Current.user&.email_address %></span>
            </div>
            <%= button_to session_path, method: :delete, form: { data: { turbo: false } }, class: "flex items-center gap-2 px-4 py-2 text-sm font-bold text-error bg-error/10 border border-error/20 rounded-lg hover:bg-error/20 transition-colors shrink-0 ml-3" do %>
              <span class="material-symbols-outlined text-[16px]">logout</span>
              <%= t('settings.account.logout') %>
            <% end %>
          </div>
        </section>
      </div>

      <!-- Action Footer -->
      <footer class="flex justify-end items-center gap-3 px-8 py-6 bg-surface-container border-t border-outline-variant shrink-0">
        <button data-action="click->settings#close" class="px-5 py-2 text-sm font-medium text-on-surface-variant hover:text-on-surface transition-colors">
          <%= t('settings.cancel')%>
        </button>
        <button data-action="click->settings#save" class="px-6 py-2 text-sm font-bold bg-primary text-on-primary rounded-lg shadow-lg shadow-primary/20 hover:opacity-90 active:scale-[0.98] transition-all">
          <%= t('settings.save')%>
        </button>
      </footer>
    </div>
  </div>
<% end %>
