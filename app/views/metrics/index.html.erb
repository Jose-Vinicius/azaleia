<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet">
  <script id="tailwind-config">
        tailwind.config = {
          darkMode: "class",
          theme: {
            extend: {
              "colors": {
                "on-error-container": "#fca5a5",
                "on-tertiary-fixed": "#003318",
                "on-secondary-container": "#a1a1aa",
                "tertiary-fixed-dim": "#6ee7b7",
                "surface-container-lowest": "#09090b",
                "surface-tint": "#a78bfa",
                "secondary-fixed-dim": "#71717a",
                "on-secondary": "#09090b",
                "on-surface-variant": "#a1a1aa",
                "on-error": "#1a0000",
                "surface-variant": "#18181b",
                "error": "#ef4444",
                "secondary-container": "#27272a",
                "primary": "#a78bfa",
                "outline": "#52525b",
                "on-primary-fixed-variant": "#5b21b6",
                "inverse-surface": "#fafafa",
                "on-surface": "#fafafa",
                "error-container": "#3b1111",
                "on-tertiary": "#001a12",
                "surface-dim": "#0c0c0f",
                "secondary": "#71717a",
                "on-tertiary-container": "#bbf7d0",
                "tertiary-container": "#065f46",
                "primary-fixed-dim": "#c4b5fd",
                "secondary-fixed": "#a1a1aa",
                "background": "#09090b",
                "surface-container-low": "#0f0f12",
                "surface-container-highest": "#1e1e22",
                "surface-bright": "#18181b",
                "on-primary": "#0a0012",
                "on-primary-container": "#ede9fe",
                "tertiary-fixed": "#bbf7d0",
                "on-tertiary-fixed-variant": "#047857",
                "primary-container": "#7c3aed",
                "on-secondary-fixed": "#18181b",
                "on-background": "#fafafa",
                "inverse-primary": "#5b21b6",
                "surface": "#0c0c0f",
                "surface-container-high": "#18181b",
                "primary-fixed": "#ede9fe",
                "on-secondary-fixed-variant": "#3f3f46",
                "on-primary-fixed": "#2e1065",
                "tertiary": "#34d399",
                "surface-container": "#121215",
                "outline-variant": "#27272a",
                "inverse-on-surface": "#09090b"
              },
              "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
              },
              "fontFamily": {
                "headline": ["Geist", "sans-serif"],
                "body": ["Geist", "sans-serif"],
                "label": ["Geist", "sans-serif"]
              }
            }
          }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
      input[type="date"]::-webkit-calendar-picker-indicator { filter: invert(1); }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-surface h-screen w-full overflow-hidden flex flex-col md:flex-row selection:bg-primary/30 selection:text-primary";
    });
  </script>
<% end %>

<!-- Desktop Side Navigation -->
<nav class="hidden md:flex flex-col h-screen sticky left-0 top-0 w-64 bg-[#09090b] border-r border-[#27272a] font-['Geist'] tracking-tight flex-shrink-0 z-50">
  <div class="flex items-center">
    <%= image_tag "logo.png", class: "w-24 h-24 object-contain" %>
    <h2 class="text-xl font-black text-[#fafafa] tracking-tighter">Azaleia</h2>
  </div>
  <div class="px-4 py-2">
    <%= link_to new_task_path, data: { turbo_frame: "modal" }, class: "w-full flex items-center justify-center gap-2 bg-primary text-on-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98] shadow-[0_0_0_1px_rgba(167,139,250,0.1)]" do %>
      <span class="material-symbols-outlined text-sm" data-icon="add">add</span>
      <%= t('layouts.side_bar.add_task')%>
    <% end %>
  </div>
  <div class="flex-1 flex flex-col px-3 py-2 space-y-1">
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= inbox_index_path %>">
      <span class="material-symbols-outlined" data-icon="inbox">inbox</span>
      <span>Inbox</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= dashboard_index_path %>">
      <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
      <span>Dashboard</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a78bfa] bg-[#18181b] border-r-2 border-[#a78bfa] font-semibold transition-all duration-150 active:scale-[0.98]" href="<%= metrics_path %>">
      <span class="material-symbols-outlined" data-icon="bar_chart" data-weight="fill" style='font-variation-settings: "FILL" 1;'>bar_chart</span>
      <span>Métricas</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= history_index_path %>">
      <span class="material-symbols-outlined" data-icon="history">history</span>
      <span>Histórico</span>
    </a>
    <div class="flex-1"></div>
    <!-- User Account Dropdown -->
    <div class="relative" data-controller="dropdown">
      <button data-action="click->dropdown#toggle" class="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98] text-left">
        <span class="material-symbols-outlined text-[20px]">account_circle</span>
        <span class="text-sm truncate flex-1"><%= Current.user&.email_address %></span>
        <span class="material-symbols-outlined text-[16px]">expand_more</span>
      </button>
      <div data-dropdown-target="menu" class="hidden absolute bottom-full left-3 right-3 mb-1 bg-[#18181b] border border-[#27272a] rounded-lg shadow-xl overflow-hidden z-50">
        <%= button_to session_path, method: :delete, form: { data: { turbo: false } }, class: "w-full flex items-center gap-3 px-4 py-3 text-sm text-[#fca5a5] hover:bg-[#27272a] transition-colors text-left" do %>
          <span class="material-symbols-outlined text-[18px]">logout</span>
          <span>Sair da Conta</span>
        <% end %>
      </div>
    </div>
    <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" do %>
      <span class="material-symbols-outlined">settings</span>
      <span><%= t('layouts.side_bar.settings')%></span>
    <% end %>
  </div>
</nav>

<!-- Main Content Area -->
<main class="flex-1 flex flex-col h-full w-full relative">
  <!-- Desktop Header -->
  <header class="hidden md:flex flex-col gap-2 pt-10 pb-6 px-10 border-b border-[#27272a]/50 bg-[#09090b]/80 backdrop-blur-xl z-20 sticky top-0">
    <div class="flex items-center gap-3 text-on-surface-variant group">
      <span class="material-symbols-outlined text-2xl group-hover:text-primary transition-colors duration-300" data-icon="bar_chart" data-weight="fill" style="font-variation-settings: 'FILL' 1;">bar_chart</span>
      <h1 class="text-3xl font-black text-transparent bg-clip-text bg-gradient-to-r from-on-surface to-on-surface/70 tracking-tighter">Painel de Métricas</h1>
    </div>
  </header>

  <!-- Mobile Header Area -->
  <div class="md:hidden pt-8 px-6 pb-4 md:border-b border-zinc-800/60 sticky top-0 z-40 bg-zinc-950/90 backdrop-blur-xl md:bg-transparent">
    <div class="flex items-center justify-between">
      <div class="flex flex-col gap-1">
        <div class="w-8 h-1 bg-violet-400 rounded-full md:hidden mb-2"></div>
        <h1 class="text-3xl md:text-3xl font-black tracking-tight text-zinc-50 drop-shadow-sm">Métricas</h1>
      </div>
      <%= link_to new_task_path, data: { turbo_frame: "modal" }, class: "md:hidden w-10 h-10 flex items-center justify-center bg-violet-500 text-zinc-100 rounded-full shadow-[0_0_15px_rgba(139,92,246,0.3)] hover:scale-105 active:scale-95 transition-all" do %>
        <span class="material-symbols-outlined text-[20px]" style="font-variation-settings: 'wght' 600">add</span>
      <% end %>
    </div>
  </div>

  <!-- Content -->
  <div class="flex-1 overflow-y-auto hide-scrollbar px-4 md:px-10 py-6 mb-20 md:mb-0">
    
    <!-- Filtros de Data -->
    <div class="bg-[#18181b] rounded-xl p-4 md:p-5 border border-[#27272a] shadow-sm mb-6 flex flex-col md:flex-row md:items-center gap-4 justify-between">
      <div>
        <h3 class="text-sm font-semibold tracking-wide text-[#fafafa] uppercase">Período de Análise</h3>
        <p class="text-xs text-[#a1a1aa] mt-0.5">Defina a janela de dias para filtrar todas as métricas abaixo.</p>
      </div>
      
      <form action="<%= metrics_path %>" method="get" class="flex flex-col sm:flex-row items-center gap-3">
        <label class="flex flex-col w-full sm:w-auto">
          <span class="text-xs text-[#a1a1aa] font-medium mb-1">Data Inicial</span>
          <input type="date" name="start_date" value="<%= @start_date %>" onchange="this.form.submit()"
                 class="bg-[#09090b] border border-[#27272a] text-[#fafafa] text-sm rounded-lg focus:ring-primary focus:border-primary block p-2.5">
        </label>
        <span class="text-[#52525b] hidden sm:block mt-5"><span class="material-symbols-outlined">arrow_right_alt</span></span>
        <label class="flex flex-col w-full sm:w-auto">
          <span class="text-xs text-[#a1a1aa] font-medium mb-1">Data Final</span>
          <input type="date" name="end_date" value="<%= @end_date %>" onchange="this.form.submit()"
                 class="bg-[#09090b] border border-[#27272a] text-[#fafafa] text-sm rounded-lg focus:ring-primary focus:border-primary block p-2.5">
        </label>
      </form>
    </div>

    <!-- 5 Cards de Totais -->
    <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
      
      <!-- Tempo Total -->
      <div class="bg-gradient-to-br from-[#18181b] to-[#09090b] border border-[#27272a] p-4 rounded-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 p-3 opacity-10 text-primary">
          <span class="material-symbols-outlined text-5xl">schedule</span>
        </div>
        <span class="text-xs text-[#a1a1aa] font-medium uppercase tracking-wider mb-2">Tempo Gasto</span>
        <div class="text-2xl font-black text-[#fafafa] mt-auto">
          <% h = @total_minutes.to_i / 60; m = @total_minutes.to_i % 60 %>
          <%= "#{h}h " if h > 0 %><%= "#{m}m" if m > 0 || h == 0 %>
        </div>
      </div>

      <!-- Tarefas Completas -->
      <div class="bg-gradient-to-br from-[#18181b] to-[#09090b] border border-[#27272a] p-4 rounded-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 p-3 opacity-10 text-emerald-500">
          <span class="material-symbols-outlined text-5xl">check_circle</span>
        </div>
        <span class="text-xs text-[#a1a1aa] font-medium uppercase tracking-wider mb-2">Concluídas</span>
        <div class="text-2xl font-black text-emerald-400 mt-auto">
          <%= @total_completed %>
        </div>
      </div>

      <!-- Tarefas Descartadas -->
      <div class="bg-gradient-to-br from-[#18181b] to-[#09090b] border border-[#27272a] p-4 rounded-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 p-3 opacity-10 text-rose-500">
          <span class="material-symbols-outlined text-5xl">cancel</span>
        </div>
        <span class="text-xs text-[#a1a1aa] font-medium uppercase tracking-wider mb-2">Descartadas</span>
        <div class="text-2xl font-black text-rose-400 mt-auto">
          <%= @total_discarded %>
        </div>
      </div>

      <!-- Tarefas Pendentes -->
      <div class="bg-gradient-to-br from-[#18181b] to-[#09090b] border border-[#27272a] p-4 rounded-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 p-3 opacity-10 text-yellow-400">
          <span class="material-symbols-outlined text-5xl">pending_actions</span>
        </div>
        <span class="text-xs text-[#a1a1aa] font-medium uppercase tracking-wider mb-2">Pendentes</span>
        <div class="text-2xl font-black text-yellow-400 mt-auto">
          <%= @total_scheduled %>
        </div>
      </div>

      <!-- Tarefas no Inbox -->
      <div class="bg-gradient-to-br from-[#18181b] to-[#09090b] border border-[#27272a] p-4 rounded-xl relative overflow-hidden flex flex-col">
        <div class="absolute top-0 right-0 p-3 opacity-10 text-blue-400">
          <span class="material-symbols-outlined text-5xl">inbox</span>
        </div>
        <span class="text-xs text-[#a1a1aa] font-medium uppercase tracking-wider mb-2">Inbox</span>
        <div class="text-2xl font-black text-blue-400 mt-auto">
          <%= @total_inbox %>
        </div>
      </div>

    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      
      <!-- Heatmap -->
      <div class="bg-[#18181b] rounded-xl p-5 border border-[#27272a] flex flex-col">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary text-xl">grid_view</span>
          <h3 class="text-sm font-semibold tracking-wide text-[#fafafa] uppercase">Heatmap (Score de Conclusão)</h3>
        </div>
        <div class="flex flex-wrap gap-1.5 justify-start flex-1 content-start">
          <% (@start_date..@end_date).each do |date| %>
            <% day_data = @heatmap_data.key?(date.to_s) ? @heatmap_data[date.to_s] : { score: 0, count: 0 } %>
            <% score = day_data[:score] %>
            <% count = day_data[:count] %>
            <% bg_class = if score >= 10
                            'bg-violet-500'
                          elsif score >= 5
                            'bg-violet-500/70'
                          elsif score > 0
                            'bg-violet-500/40'
                          else
                            'bg-[#27272a]'
                          end %>
            <div class="w-[1.125rem] h-[1.125rem] rounded-[2px] <%= bg_class %> cursor-pointer hover:ring-2 hover:ring-offset-1 hover:ring-offset-[#18181b] hover:ring-violet-400 transition-all" title="<%= date.strftime('%d/%m/%Y') %>: <%= score %> pontos (<%= count %> <%= count == 1 ? 'tarefa concluída' : 'tarefas concluídas' %>)"></div>
          <% end %>
        </div>
        <div class="flex items-center justify-end gap-1.5 mt-4 text-[10px] text-[#71717a] font-medium">
          <span>Menos</span>
          <div class="w-3 h-3 rounded-[2px] bg-[#27272a]"></div>
          <div class="w-3 h-3 rounded-[2px] bg-violet-500/40"></div>
          <div class="w-3 h-3 rounded-[2px] bg-violet-500/70"></div>
          <div class="w-3 h-3 rounded-[2px] bg-violet-500"></div>
          <span>Mais</span>
        </div>
      </div>

      <!-- Top 5 Tasks -->
      <div class="bg-[#18181b] rounded-xl p-5 border border-[#27272a] flex flex-col">
        <div class="flex items-center gap-2 mb-4">
          <span class="material-symbols-outlined text-primary text-xl">local_fire_department</span>
          <h3 class="text-sm font-semibold tracking-wide text-[#fafafa] uppercase">Top 5 Tarefas (Tempo Investido)</h3>
        </div>
        <div class="flex flex-col gap-3 flex-1 overflow-y-auto">
          <% if @top_tasks.empty? %>
            <div class="flex-1 flex items-center justify-center">
              <p class="text-sm text-[#a1a1aa] font-medium">Nenhum tempo logado neste período.</p>
            </div>
          <% else %>
            <% @top_tasks.each_with_index do |task, index| %>
              <div class="p-3 bg-[#09090b] rounded-lg border border-[#27272a] hover:border-primary/50 transition-colors flex justify-between items-center group cursor-default">
                <div class="flex items-center gap-3 overflow-hidden">
                  <div class="w-6 h-6 rounded bg-[#18181b] text-xs font-bold text-[#fafafa] flex items-center justify-center border border-[#27272a]">
                    <%= index + 1 %>
                  </div>
                  <span class="text-[#fafafa] text-sm font-medium truncate group-hover:text-primary transition-colors"><%= task.title %></span>
                </div>
                <div class="flex items-center gap-1.5 text-sm font-semibold text-primary/80 whitespace-nowrap bg-primary/10 px-2 py-0.5 rounded ml-2">
                  <span class="material-symbols-outlined text-[14px]">schedule</span>
                  <% h = task.period_duration.to_i / 60; m = task.period_duration.to_i % 60 %>
                  <span><%= "#{h}h" if h > 0 %> <%= "#{m}m" if m > 0 || h == 0 %></span>
                </div>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
      
    </div>
  </div>
</main>

<!-- Mobile Bottom Navigation -->
<nav class="md:hidden flex justify-between items-center h-16 px-1 pb-safe bg-zinc-950/90 backdrop-blur-lg fixed bottom-0 w-full z-50 border-t border-zinc-800 shadow-2xl">
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= inbox_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">inbox</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Inbox</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= dashboard_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">dashboard</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Dashboard</span>
  </a>
  <a class="flex flex-col items-center justify-center text-violet-400 scale-105 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full relative" href="#">
    <div class="absolute -top-1 w-8 h-1 bg-violet-400 rounded-b-full"></div>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 1;">bar_chart</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Métricas</span>
  </a>
  <a class="flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" href="<%= history_index_path %>">
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">history</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Histórico</span>
  </a>
  <%= link_to settings_path, data: { turbo_frame: "modal" }, class: "flex flex-col items-center justify-center text-zinc-500 tap-highlight-transparent active:scale-90 transition-transform flex-1 h-full" do %>
    <span class="material-symbols-outlined text-2xl mb-0.5" style="font-variation-settings: 'FILL' 0;">settings</span>
    <span class="text-[10px] font-medium tracking-wide uppercase truncate w-full text-center px-1">Settings</span>
  <% end %>
</nav>
