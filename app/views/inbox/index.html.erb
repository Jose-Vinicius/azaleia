<% content_for :head do %>
  <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
  <link href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
  <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap" rel="stylesheet"/>
  <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "inverse-surface": "#fafafa",
                        "inverse-on-surface": "#09090b",
                        "surface-tint": "#a78bfa",
                        "on-primary-fixed": "#2e1065",
                        "error": "#ef4444",
                        "background": "#09090b",
                        "on-primary": "#0a0012",
                        "tertiary-container": "#065f46",
                        "on-tertiary-fixed-variant": "#047857",
                        "on-primary-fixed-variant": "#5b21b6",
                        "outline": "#52525b",
                        "on-surface": "#fafafa",
                        "on-secondary-fixed-variant": "#3f3f46",
                        "surface-variant": "#18181b",
                        "surface-container-low": "#0f0f12",
                        "secondary": "#71717a",
                        "surface-dim": "#0c0c0f",
                        "surface": "#0c0c0f",
                        "on-tertiary-container": "#bbf7d0",
                        "on-background": "#fafafa",
                        "primary-container": "#7c3aed",
                        "primary": "#a78bfa",
                        "outline-variant": "#27272a",
                        "tertiary": "#34d399",
                        "surface-bright": "#18181b",
                        "surface-container-high": "#18181b",
                        "on-tertiary-fixed": "#003318",
                        "secondary-container": "#27272a",
                        "surface-container": "#121215",
                        "on-surface-variant": "#a1a1aa",
                        "on-error": "#1a0000",
                        "tertiary-fixed": "#bbf7d0",
                        "on-tertiary": "#001a12",
                        "secondary-fixed": "#a1a1aa",
                        "inverse-primary": "#5b21b6",
                        "tertiary-fixed-dim": "#6ee7b7",
                        "surface-container-lowest": "#09090b",
                        "secondary-fixed-dim": "#71717a",
                        "on-secondary-container": "#a1a1aa",
                        "on-error-container": "#fca5a5",
                        "primary-fixed": "#ede9fe",
                        "surface-container-highest": "#1e1e22",
                        "on-secondary": "#09090b",
                        "primary-fixed-dim": "#c4b5fd",
                        "on-secondary-fixed": "#18181b",
                        "on-primary-container": "#ede9fe",
                        "error-container": "#3b1111"
                    },
                    "borderRadius": {
                        "DEFAULT": "0.25rem",
                        "lg": "0.5rem",
                        "xl": "0.75rem",
                        "full": "9999px"
                    },
                    "fontFamily": {
                        "headline": ["Geist", "sans-serif"],
                        "body": ["Geist", "sans-serif"],
                        "label": ["Geist", "sans-serif"]
                    }
                }
            }
        }
  </script>
  <style>
      body { font-family: 'Geist', sans-serif; }
      .hide-scrollbar::-webkit-scrollbar { display: none; }
      .hide-scrollbar { -ms-overflow-style: none; scrollbar-width: none; }
  </style>
  <script>
    document.documentElement.classList.add('dark');
    document.addEventListener("turbo:load", () => {
      document.body.className = "bg-background text-on-background h-screen w-full overflow-hidden flex flex-col md:flex-row antialiased font-body selection:bg-primary-container selection:text-on-primary-container";
    });
    document.addEventListener("DOMContentLoaded", () => {
      document.body.className = "bg-background text-on-background h-screen w-full overflow-hidden flex flex-col md:flex-row antialiased font-body selection:bg-primary-container selection:text-on-primary-container";
    });
  </script>
<% end %>

<!-- Mobile Top App Bar (Hidden on md+) -->
<header class="md:hidden flex items-center justify-between px-6 py-4 sticky top-0 z-40 w-full bg-[#09090b]/80 backdrop-blur-md border-b border-[#27272a]">
  <div class="flex items-center gap-3">
    <h1 class="text-lg font-bold text-[#fafafa] tracking-tight">Inbox</h1>
  </div>
  <div class="flex items-center gap-4 text-[#a1a1aa]">
    <button aria-label="Settings" class="hover:text-[#fafafa] transition-colors focus:ring-2 focus:ring-[#a78bfa] rounded-full p-1">
      <span class="material-symbols-outlined" data-icon="settings">settings</span>
    </button>
  </div>
</header>

<!-- Side Navigation (Visible on md+) -->
<nav class="hidden md:flex flex-col h-screen sticky left-0 top-0 w-64 bg-[#09090b] border-r border-[#27272a] font-['Geist'] tracking-tight flex-shrink-0 z-50">
  <div class="p-6">
    <h2 class="text-xl font-black text-[#fafafa] tracking-tighter">Azaleia</h2>
    <p class="text-xs text-on-surface-variant font-medium tracking-wide mt-1 uppercase"></p>
  </div>
  <div class="px-4 py-2">
    <%= link_to new_task_path, class: "w-full flex items-center justify-center gap-2 bg-primary text-on-primary font-semibold py-2.5 px-4 rounded-lg hover:bg-primary-fixed transition-colors active:scale-[0.98] shadow-[0_0_0_1px_rgba(167,139,250,0.1)]" do %>
      <span class="material-symbols-outlined text-sm" data-icon="add">add</span>
      Add Task
    <% end %>
  </div>
  <div class="flex-1 px-3 py-2 space-y-1">
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a78bfa] bg-[#18181b] border-r-2 border-[#a78bfa] font-semibold transition-all duration-150 active:scale-[0.98]" href="#">
      <span class="material-symbols-outlined" data-icon="inbox" data-weight="fill" style='font-variation-settings: "FILL" 1;'>inbox</span>
      <span>Inbox</span>
    </a>
    <a class="flex items-center gap-3 px-3 py-2.5 rounded-lg text-[#a1a1aa] hover:text-[#fafafa] hover:bg-[#18181b] transition-all duration-150 active:scale-[0.98]" href="<%= dashboard_index_path %>">
      <span class="material-symbols-outlined" data-icon="dashboard">dashboard</span>
      <span>Dashboard</span>
    </a>
  </div>
</nav>

<!-- Main Content Canvas -->
<main class="flex-1 flex flex-col h-full w-full overflow-hidden bg-background relative max-w-5xl mx-auto md:px-8">
  <!-- Desktop Header (Visible on md+, replaces Mobile Top App Bar functionality for desktop) -->
  <div class="hidden md:flex items-center justify-between py-10 px-6 w-full">
    <h1 class="text-3xl font-headline font-bold text-on-background tracking-tight">INBOX</h1>
    <div class="flex items-center gap-4">
    </div>
  </div>

  <!-- Task List Area -->
  <div class="flex-1 overflow-y-auto hide-scrollbar px-6 pb-24 md:pb-12 space-y-2 w-full" id="inbox">
    <!-- Mobile Title (Hidden on md+) -->
    <h2 class="md:hidden text-2xl font-headline font-bold text-on-background tracking-tight py-4 mb-2">INBOX</h2>
    
    <% @tasks.each do |task| %>
      <%= render task %>
    <% end %>
  </div>
</main>

<!-- Mobile FAB (Visible only on md- down) -->
<div class="md:hidden fixed bottom-6 right-6 z-50">
  <%= link_to new_task_path, aria: {label: "Add Task"}, class: "w-14 h-14 bg-primary text-on-primary rounded-full shadow-lg flex items-center justify-center hover:bg-primary-fixed transition-colors active:scale-95 focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 focus:ring-offset-background" do %>
    <span class="material-symbols-outlined text-2xl" data-icon="add">add</span>
  <% end %>
</div>